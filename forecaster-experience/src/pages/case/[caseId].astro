---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 체험 메인 (단계 상태머신): 종관분석→모델검토→불확실성→판단→검증→리플렉션.
// 정적 출력이므로 케이스 경로를 사전 생성한다 (§1.5 3케이스).
export function getStaticPaths() {
  return [
    { params: { caseId: 'easy-highpressure' } },
    { params: { caseId: '20220808-seoul' } },
    { params: { caseId: 'trap-echo' } },
  ];
}

const { caseId } = Astro.params;
---

<BaseLayout title={`체험 · ${caseId}`}>
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-2xl font-bold">케이스: {caseId}</h1>
    <p class="mt-2 text-slate-600">단계 상태머신 (스캐폴드 — 추후 구현).</p>
  </main>
</BaseLayout>
