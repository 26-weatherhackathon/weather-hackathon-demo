# Weather Hackathon Demo - Environment Variables Template

# 공공데이터포털 API 키 (기상청 단기예보)
# 출처: https://www.data.go.kr/
# 서비스: 단기예보 조회서비스, 초단기실황 조회
KMA_PUBLIC_DATA_KEY=your_api_key_here

# 기상청 API 허브 키 (지상관측)
# 출처: https://apihub.kma.go.kr/
# 서비스: 기상청 API 허브
KMA_API_HUB_KEY=your_api_key_here

# 선택사항: Vercel 배포용 (Legacy)
KMA_API_KEY=your_api_key_here
